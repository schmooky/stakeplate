{
  "name": "game",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:screenshots": "playwright test",
    "test:e2e": "playwright test --config=playwright.scenarios.config.ts",
    "assets:pack": "assetpack",
    "assets:watch": "assetpack -w"
  },
  "dependencies": {
    "@fontsource/roboto-condensed": "^5.2.0",
    "@lucky-magnet/stake-protocol": "workspace:*",
    "@open-slot-ui/core": "^0.9.0",
    "@open-slot-ui/pixi": "^0.9.0",
    "gsap": "^3.13.0",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.1.0",
    "pixi-reels": "^1.1.0",
    "pixi.js": "^8.11.0",
    "preact": "^10.26.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@playwright/test": "^1.50.0",
    "@assetpack/cli": "^0.8.0",
    "@assetpack/core": "^1.7.0",
    "@preact/preset-vite": "^2.10.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "peerDependenciesMeta": {
    "@esotericsoftware/spine-pixi-v8": {
      "optional": true
    }
  }
}
